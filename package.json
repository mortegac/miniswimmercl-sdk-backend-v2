{
  "name": "backoffice",
  "version": "1.0.0",
  "description": "MytAscensores Backoffice - AWS AppSync GraphQL API",
  "private": true,
  "type": "module",
  "workspaces": [
    "infrastructure",
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky",
    "infra:deploy": "npm run deploy --workspace=infrastructure",
    "infra:destroy": "npm run destroy --workspace=infrastructure",
    "infra:synth": "npm run synth --workspace=infrastructure",
    "backend:build": "npm run build --workspace=backend",
    "backend:test": "npm run test --workspace=backend",
    "backend:lint": "npm run lint --workspace=backend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend"
  },
  "devDependencies": {
    "@aws-amplify/backend-cli": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "npm run backend:test",
      "npm run backend:lint"
    ]
  }
}
